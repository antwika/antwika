{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Conan install",
            "type": "shell",
            "command": "conan install . -of build -pr:b=./profiles/build/${env:CONAN_PROFILE} -pr:h=./profiles/host/${env:CONAN_PROFILE} --build=missing -s build_type=Release",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "CMake preset conan-release",
            "type": "shell",
            "command": "cmake --preset conan-release",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "CMake build",
            "type": "shell",
            "command": "cmake --build build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "ctest --test-dir build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Build apps/app",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Conan install",
                "CMake preset conan-release",
                "CMake build",
                "Test"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}