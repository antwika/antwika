{
    "name": "MinGW Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "../.."
    },
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "remoteUser": "ubuntu",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shellArgs.linux": [
                    "-l"
                ]
            },
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    },
    "containerEnv": {
        "CONAN_PROFILE": "mingw-windows-x86_64"
    }
}